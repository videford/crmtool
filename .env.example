# ---- Core ----
# Local docker-compose injects DATABASE_URL automatically. For Railway, the
# PostgreSQL plugin sets it. Override here only for non-docker local runs.
# DATABASE_URL=postgresql+asyncpg://crm:crm@localhost:5432/crm

# Secret for signing session cookies. Generate: python -c "import secrets;print(secrets.token_hex(32))"
SESSION_SECRET=change-me-in-prod

# Public base URL of the web service (used in Telegram messages / deep links)
BASE_URL=http://localhost:8000

# Default timezone for meeting reminders / display
TIMEZONE=Europe/Moscow

# ---- Seed admin (created on first boot if no users exist) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin

# ---- Self-registration ----
# Allow visitors to register at /register (true/false)
ALLOW_REGISTRATION=true
# Role assigned to self-registered users: admin | manager | viewer
DEFAULT_ROLE=manager

# ---- Telegram (optional; bot/worker idle gracefully if unset) ----
TELEGRAM_BOT_TOKEN=
# Bot username without @ (e.g. crm_tool_bot) — enables one-tap account linking
# from Settings via a t.me deep link.
TELEGRAM_BOT_USERNAME=
# Reminder offsets in minutes before a meeting, comma-separated
REMINDER_OFFSETS=1440,60,15

# ---- Linear (optional) ----
LINEAR_API_KEY=
LINEAR_TEAM_ID=
# Secret configured on the Linear webhook to verify inbound requests
LINEAR_WEBHOOK_SECRET=
